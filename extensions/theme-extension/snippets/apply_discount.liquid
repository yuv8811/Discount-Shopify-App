<div class="discount-box">
  <input
    type="text"
    id="discount-code-input"
    placeholder="Enter discount code"
  />

  <button onclick="handleApplyButtonClick()">
    Apply
  </button>
</div>

<script>
  async function handleApplyButtonClick() {
    var input = document.getElementById("discount-code-input");
    var button = document.querySelector(".discount-box button");
    var code = input.value.trim();

    if (!code) {
      alert("Enter a discount code");
      return;
    }

    // Show loading state
    button.disabled = true;
    button.innerText = "Applying...";
    button.style.opacity = "0.7";

    if (window.applyDiscountCode) {
      await window.applyDiscountCode(code);
    } else {
      window.location.href = "/discount/" + encodeURIComponent(code) + "?redirect=/cart";
    }
  }
</script>

<style>
  .discount-box {
    display: flex;
    gap: 8px;
    margin: 10px 0;
  }

  .discount-box input {
    flex: 1;
    padding: 8px;
    border: 1px solid #ccc;
    border-radius: 4px;
  }

  .discount-box button {
    padding: 8px 16px;
    cursor: pointer;
    background-color: #008060;
    color: white;
    border: none;
    border-radius: 4px;
  }
</style>
